# Hetzner / VPS production template. Copy to project root as .env on the server:
#   cp deploy/env.hetzner.example .env
#
# Generate a bcrypt hash for Caddy basic auth (recommended on the public internet):
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'

# --- Required for docker-compose.hetzner.yml ---
DASHBOARD_DOMAIN=dashbird.example.com
CADDY_EMAIL=you@example.com

# Strongly recommended: HTTP basic auth in front of the whole site (chat uses OpenRouter).
DASHBOARD_BASIC_AUTH_USER=dashbird
DASHBOARD_BASIC_AUTH_HASH=

# Public origin for sidebar links (HTTPS, no trailing slash).
DASHBOARD_LAN_ORIGIN=https://dashbird.example.com

# --- App secrets ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
CHAT_RATE_LIMIT_PER_MINUTE=12

# --- Calendar & location (same as local) ---
GOOGLE_CALENDAR_ICAL_URL=
WEATHER_LAT=37.848
WEATHER_LON=-122.253
WEATHER_ZIP=94608
DASHBOARD_LOCATION_LABEL=Oakland, CA
SF_WEATHER_LAT=37.7749
SF_WEATHER_LON=-122.4194

# Production: only show air quality panel when AQI is elevated.
AIR_QUALITY_FORCE_SHOW=0

# NWS requires a descriptive User-Agent with contact email.
NWS_USER_AGENT=Dashbird/1.0 (you@example.com)

# Optional spend / backup metadata
# LAST_BACKUP_AT=2026-05-10T18:30:00-07:00

# Features disabled on cloud (no local desktop / X11):
# Do not set KDENLIVE_APPIMAGE, DBUS_*, or HOST_APPLICATIONS_DIR.
