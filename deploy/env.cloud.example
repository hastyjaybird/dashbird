# Vultr / public VPS production template.
# Copy to project root as .env on the server:
#   cp deploy/env.cloud.example .env
#
# Generate bcrypt hash for Caddy basic auth:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'

# Optional metadata:
# DEPLOY_SCOPE=personal
# DEPLOY_SERVER_NAME=personal-dashbird-vultr-sjc-01
# DEPLOY_VISIBILITY_TIER=tier3-private

# --- Required for docker-compose.cloud.yml ---
JAYHASTY_ROOT_DOMAIN=jayhasty.com
PORTFOLIO_DOMAIN=portfolio.jayhasty.com
# Space-separated hostnames for Dashbird (Caddy site addresses; keep duckdns during cutover).
DASHBOARD_DOMAIN=dashbird.jayhasty.com dashbird.duckdns.org
CADDY_EMAIL=you@example.com

# HTTP basic auth (required on the public internet).
# Hash from: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
# IMPORTANT: in this .env file for Docker Compose, escape every `$` as `$$`
#   e.g. $2a$14$abcd...  →  $$2a$$14$$abcd...
DASHBOARD_BASIC_AUTH_USER=dashbird
DASHBOARD_BASIC_AUTH_HASH=

# Trusted devices: ONLY these device IDs skip the password (Jay home Linux + phone).
# Bookmark once per device: https://dashbird.jayhasty.com/auth/device-bind?did=<id>
# Generate secret: openssl rand -base64 48
# Leave unset on LAN-only docker-compose.yml (no cloud gate).
DASHBOARD_TRUSTED_DEVICE_SECRET=
DASHBOARD_TRUSTED_DEVICE_IDS=edd37155-3ffe-4d18-a775-d6cdcedbf343,1c0c1947-ad36-4032-aed5-00eb5b28e166
# Optional cookie lifetime in days (default 365).
# DASHBOARD_TRUSTED_DEVICE_DAYS=365

# Public origin for sidebar links (HTTPS, no trailing slash).
DASHBOARD_LAN_ORIGIN=https://dashbird.jayhasty.com

# Slim cloud image: do not run Playwright Chromium on 2 GB VPS.
# Existing tool images in data/tool-library-assets/ still serve normally.
# New Playwright snapshots: enrich on LAN, then rsync assets up.
TOOL_LIBRARY_SCREENSHOT=0

# --- Big Events research on cloud (no headless browser here) ---
# LAN discovers event URLs / fliers via headless Chrome. The slim cloud image
# can't, and datacenter IPs get bot-challenged, so Big Events added on cloud
# won't find a URL, correct the name, or pull a thumbnail without this.
# Brave Search API (free tier ≈ 2k queries/month, $0): https://api.search.brave.com
# Used only as a fallback when the browser path is unavailable/empty.
BRAVE_SEARCH_API_KEY=
# Name / date / price extraction from the fetched page uses OpenRouter (plain
# HTTPS, works from datacenter). Required for name correction to work on cloud.
OPENROUTER_API_KEY=

# --- Vikunja (todos; internal Docker network) ---
VIKUNJA_BASE_URL=http://vikunja:3456
VIKUNJA_SERVICE_PUBLICURL=https://dashbird.jayhasty.com/
VIKUNJA_SERVICE_SECRET=generate-a-long-random-string
VIKUNJA_TOKEN=
VIKUNJA_PROJECT_ID=1
# VIKUNJA_ARCHIVE_PROJECT_ID=

# Do Random Task: geofence for "makerfarm" context (defaults to Bay Area Maker Farm, Alameda).
# TASK_MAKERFARM_LAT=37.765
# TASK_MAKERFARM_LON=-122.241
# Optional paths: TASK_RANDOM_META_PATH=, TASK_PROJECT_LOCATIONS_MD_PATH=
VIKUNJA_SERVICE_ENABLEREGISTRATION=false

# --- Calendar & location ---
GOOGLE_CALENDAR_ICAL_URL=
WEATHER_LAT=37.848
WEATHER_LON=-122.253
WEATHER_ZIP=94608
DASHBOARD_LOCATION_LABEL=Oakland, CA
SF_WEATHER_LAT=37.7749
SF_WEATHER_LON=-122.4194

AIR_QUALITY_FORCE_SHOW=0
NWS_USER_AGENT=Dashbird/1.0 (you@example.com)

# Gmail OAuth redirect must match the public HTTPS origin, e.g.:
# GMAIL_OAUTH_REDIRECT_URI=https://dashbird.jayhasty.com/api/events-finder-gmail/oauth/callback

# Facebook Apify: cloud is the sole paid scraper (daily 04:00 PT). Keep APIFY_TOKEN here;
# LAN docker-compose.yml forces FACEBOOK_EVENTS_WEEKLY=0 so only this host runs the Actor.
# APIFY_TOKEN=

# Retain events further out (post-fetch filter only; does NOT increase Apify spend).
# LAN sets 56 in docker-compose.yml; set it here too so cloud keeps the same 8-week horizon.
EVENTS_FINDER_INGEST_FUTURE_DAYS=56

# Features disabled on cloud (no local desktop / X11):
# Do not set KDENLIVE_APPIMAGE, DBUS_*, or HOST_APPLICATIONS_DIR.

# Optional spend / backup metadata
# LAST_BACKUP_AT=2026-07-15T00:00:00-07:00

# --- Off-host backups (scripts/cloud-backup.sh, host cron) ---
# The in-app scheduler writes local daily tarballs; this ships them OFF the VPS, encrypted.
# Install cron on the host (after the 03:15 in-app backup):
#   30 3 * * * /opt/dashbird/scripts/cloud-backup.sh >> /var/log/dashbird-backup.log 2>&1
#
# rclone remote:path for the encrypted artifact (e.g. Backblaze B2 / S3). Leave empty to
# keep local-only. Configure the remote with `rclone config` on the host first.
# DASHBIRD_OFFSITE_REMOTE=b2:my-bucket/dashbird
# Encryption (required before anything uploads — data/ contains OAuth tokens):
#   age keygen:  age-keygen -o ~/.dashbird-backup.key   (put the public key below)
# DASHBIRD_AGE_RECIPIENT=age1...
#   or a gpg symmetric passphrase fallback:
# DASHBIRD_GPG_PASSPHRASE=
# DASHBIRD_BACKUP_KEEP_DAYS=14
# Alert to Telegram if the host backup/upload fails (reuses TELEGRAM_BOT_TOKEN):
# DASHBIRD_ALERT_CHAT_ID=
# In-app staleness alert (see .env.example) also covers "backup went stale".
# DATA_BACKUP_ALERT_CHAT_ID=
