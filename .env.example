# Runtime (see README). Inside Docker the app listens on 3000; compose maps HOST_PORT → 3000.
PORT=3000
HOST_PORT=8787

# Optional: override auto-detected phone URL (compose `lan-url` service writes phone-lan-url.txt).
# DASHBOARD_LAN_ORIGIN=http://192.168.1.42:8787

# Client-visible dashboard settings (no secrets)
# Google Calendar: iframe "src" only (or full snippet — server extracts src). If omitted: mode=WEEK, showTitle=0; panel uses CSS dark theme. Wrap values with & in double quotes.
# If the URL contains &, wrap the whole value in double quotes (Compose/dotenv otherwise truncates at &), e.g.:
# Calendar: Public address in iCal format (Settings → Integrate calendar). Embed panel is derived from this URL.
# GOOGLE_CALENDAR_ICAL_URL="https://calendar.google.com/calendar/ical/YOUR_EMAIL/public/basic.ics"
GOOGLE_CALENDAR_ICAL_URL=
# Optional override for the Calendar iframe panel only:
# CALENDAR_EMBED_URL="https://calendar.google.com/calendar/embed?src=YOUR_EMAIL&ctz=America/Los_Angeles"
# Events finder “Add to calendar” → which Google Calendar to preselect (julia.hasty).
# Calendar ID: Google Calendar → Settings → Random Events → Integrate calendar → Calendar ID
# (looks like …@group.calendar.google.com). Name is the button label only.
EVENTS_FINDER_GOOGLE_CALENDAR_NAME=Random Events
EVENTS_FINDER_GOOGLE_CALENDAR_AUTHUSER=julia.hasty@gmail.com
EVENTS_FINDER_GOOGLE_CALENDAR_SRC=
# Primary map point for Oakland weather + NWS sunset (Open-Meteo still used for current conditions).
# Optional: set WEATHER_ZIP=94608 to derive lat/lon from that ZIP (Zippopotam); overrides WEATHER_LAT/LON when valid.
# WEATHER_ZIP=94608
# Air Quality sidebar (above Weather Radar): Open-Meteo US AQI at WEATHER_ZIP/lat+lon; PurpleAir map when AQI > 80.
# AIR_QUALITY_FORCE_SHOW=1 shows the panel regardless of AQI (default 1 for testing). Set AIR_QUALITY_FORCE_SHOW=0 for production threshold only.
# AIR_QUALITY=0 disables the panel.
WEATHER_LAT=37.848
WEATHER_LON=-122.253
# Optional IANA zone for the hero clock / sky strip when NWS is unreachable (otherwise from api.weather.gov points).
# WEATHER_TIME_ZONE=America/Los_Angeles
# Sky strip: live NASA GSFC annular-eclipse row (HTML decade table each request; ~6‑month gate). Set to 0 to disable.
# SKY_ANNULAR_ECLIPSE_NASA=0
# Testing only: force a geomagnetic row in `/api/sky-events` regardless of NOAA / Kp (strip UI tuning). Normal behavior uses noaa-scales blocks 0–3 + planar Kp.
# SKY_DEBUG_GEOMAGNETIC_ACTIVE=1
# Sky strip: live non-airline aircraft within AIRCRAFT_WATCH_RADIUS_MI of rain-alert address (adsb.fi community ADS-B). Set to 0 to disable.
# SKY_AIRCRAFT_NEARBY=0
# AIRCRAFT_WATCH_RADIUS_MI=3
# adsb.fi is queried by lat/lon/dist (NM); results are filtered to AIRCRAFT_WATCH_RADIUS_MI (statute). Personal/non-commercial; ~1 req/s limit (90s cache).
# Optional: search radius (miles) for /api/salmon-runs static run windows near WEATHER_ZIP / WEATHER_LAT+WEATHER_LON (default 50; clamped 5–200).
# SALMON_RUN_RADIUS_MI=50
# Testing only: include monarch “inactive” rows, salmon out-of-month runs, wild plants out of active month (higher caps). Unset in normal use.
# EARTH_DEBUG_SHOW_INACTIVE=1
# Earth strip: largest nearby earthquake in the last rolling week (USGS; M>3 within 30 mi of WEATHER_ZIP / WEATHER_LAT+LON). Row persists two calendar days in `WEATHER_TIME_ZONE`; event date (M/D) appears on the second day. Pin file: data/usgs-earthquake-pin.json. Set to 0 to disable.
# EARTH_USGS_QUAKE_WEEK=0
# Sidebar Market Watch (Yahoo Finance chart API; editable list persisted to data/market-watch-tickers.json). Set to 0 to disable.
# MARKET_WATCH=0
# MARKET_WATCH_TICKERS_PATH=/var/lib/dashbird/market-watch-tickers.json
# MARKET_WATCH_SETTINGS_PATH=/var/lib/dashbird/market-watch-settings.json
# MARKET_WATCH_FEAR_GREED=0
# Rain alert (hero “Rain expected in N minutes”, 2h window) uses live GPS when allowed, else WEATHER_ZIP.
# RAIN_ALERT=0
# Testing only: force hero “rain expected in N minutes” line (RAIN_ALERT_DEBUG_MINUTES, default 42).
# RAIN_ALERT_DEBUG=1
# RAIN_ALERT_DEBUG_MINUTES=42
# Optional legacy address (aircraft nearby / older clients); rain alert itself does not use Settings address.
# RAIN_ALERT_ADDRESS=1217 32nd st oakland california 94608
# RAIN_ALERT_ADDRESS_PATH=/var/lib/dashbird/rain-alert-address.json
# WEATHER_RADAR=0
# Sidebar radar: Leaflet + IEM MRMS (~20 mi) centered on device location (ZIP/config fallback).
# Hidden unless precip is active/imminent within ~20 mi. Force always-on for troubleshooting:
# WEATHER_RADAR_ALWAYS=1


# Secondary ZIP: lightning-bug season + fall foliage (Settings or data/secondary-watch-zip.json). Fireflies: Earth strip 7d before start; foliage: 21d heads-up.
# SECONDARY_WATCH=0
# SECONDARY_WATCH_ZIP=24066
# SECONDARY_WATCH_ZIP_PATH=/var/lib/dashbird/secondary-watch-zip.json
# Earth strip: strongest GOES GLM lightning flash (~200 mi of WEATHER_ZIP centroid) from NOAA open-data CFA NetCDF on S3. Set to 0 to disable.
# EARTH_GOES_GLM_LIGHTNING=0
# Optional: force AWS bucket id (normally noaa-goes18 west-of-103degW else noaa-goes16)
# EARTH_GOES_GLM_BUCKET=noaa-goes18
# Earth strip: GLM “Sprite” proxy (extreme radiant energy / area tier; persists 7 days under data/glm-sprite-events.json). GLM does not measure +CG or kA — tune thresholds. Optional absolute JSON path:
# GLM_SPRITE_STORE_PATH=/var/lib/dashbird/glm-sprite-events.json
# EARTH_SPRITE_MIN_RADIANT_J=5e10
# Optional minimum flash_area (m²) from GLM; 0 = ignore area
# EARTH_SPRITE_MIN_AREA_SQ_M=0
# Label tier for “>NkA” display alias (not measured current)
# EARTH_SPRITE_PEAK_KA_TIER=50
# Polarity label alias (display only; GLM has no stroke polarity)
# EARTH_SPRITE_POLARITY_ALIAS=+CG
# Earth strip: USA-NPN Extended Spring Index (SI-x) first-leaf window + anomaly vs 1981–2010 (GeoServer WCS). Set to 0 to disable.
# EARTH_USA_NPN_SPRING=0
# Optional override for USA-NPN GeoServer base (default http://geoserver.usanpn.org/geoserver/).
# USANPN_GEOSERVER_BASE=http://geoserver.usanpn.org/geoserver/
# Sky & Space strip (hero): Yosemite moonbow row from public/data/yosemite-moonbow-windows.json (last row when active). Set to 0 to disable.
# EARTH_YOSEMITE_MOONBOW=0
# Earth strip: Mount Diablo–area tarantula mating season (public/data/diablo-tarantula-season.json + haversine radius). Set to 0 to disable.
# EARTH_DIABLO_TARANTULA=0
# Optional: miles from Mount Diablo anchor for tarantula row (default from JSON, else 60; clamped 15–120).
# TARANTULA_DIABLO_RADIUS_MI=60
# Earth strip: Oakland salamander surface heuristic (Open-Meteo rain + air temp; Nov 1–Apr 1 + radius from downtown Oakland). Set to 0 to disable.
# EARTH_OAKLAND_SALAMANDERS=0
# Optional thresholds: min rain (inches) summed over rolling window, window hours, min air temp °F (proxy for ~40°F soil).
# SALAMANDER_OAKLAND_MIN_RAIN_IN=0.28
# SALAMANDER_OAKLAND_RAIN_HOURS=72
# SALAMANDER_OAKLAND_AIR_TEMP_F=52
# SALAMANDER_OAKLAND_RADIUS_MI=18
# Wild foraging Earth strip: static native ripeness sites (/api/wild-foraging). Default radius 75 mi; clamped 10–200.
# EDIBLE_NATIVE_PLANT_RADIUS_MI=75
# Optional Falling Fruit API key (https://fallingfruit.org/data) — adds nearby mapped edibles when set.
# FALLING_FRUIT_API_KEY=
# Max distance (meters) for Falling Fruit locations from dashboard point (default 10000). Clamped 500–50000.
# FALLING_FRUIT_MAX_DISTANCE_M=10000
# Falling Fruit /locations limit (default 28). Clamped 1–100.
# FALLING_FRUIT_LOCATION_LIMIT=28
# Optional User-Agent for Falling Fruit fetches (some stacks log it).
# FALLING_FRUIT_FETCH_UA=dashbird/1.0 (personal)
# NWS api.weather.gov requires a descriptive User-Agent (see https://www.weather.gov/documentation/services-web-api).
# NWS_USER_AGENT=Dashbird/1.0 (you@example.com)
DASHBOARD_LOCATION_LABEL=Oakland, CA

# Second city shown in hero (San Francisco default)
SF_WEATHER_LAT=37.7749
SF_WEATHER_LON=-122.4194

# Optional: network sidebar probes (defaults shown). ICMP often blocked in Docker; TCP fallback uses these.
# NET_HEALTH_PING_HOST=1.1.1.1
# NET_HEALTH_TCP_HOST=1.1.1.1
# NET_HEALTH_TCP_PORT=443
# NET_HEALTH_DOWN_BYTES=180000
# NET_HEALTH_UP_BYTES=98304

# --- Vikunja (Today's To Do panel → /api/vikunja) ---
# Local Vikunja is started by docker compose (service `vikunja`, port 3456).
# From the dashboard container use the Docker hostname; from the host use LAN/localhost.
# VIKUNJA_SERVICE_PUBLICURL=http://192.168.5.2:3456/
# VIKUNJA_SERVICE_SECRET=generate-a-long-random-string
# VIKUNJA_HOST_PORT=3456
# VIKUNJA_BASE_URL=http://vikunja:3456
# VIKUNJA_TOKEN=
# VIKUNJA_PROJECT_ID=1
# Optional: project for completed tasks (created as "Archive" if unset).
# VIKUNJA_ARCHIVE_PROJECT_ID=
# VIKUNJA_TIMEOUT_MS=15000

# --- Events Finder: Gmail intake (multi-account) ---
# Google Cloud OAuth desktop/web client with Gmail API enabled (readonly scope).
# Redirect URI must match (default uses HOST_PORT / DASHBOARD_LAN_ORIGIN):
#   http://127.0.0.1:8787/api/events-finder-gmail/oauth/callback
# Then Settings → Events sources → Connect each inbox (sign in as that address).
# Defaults: jay.intake.box@gmail.com + julia.hasty@gmail.com
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# Optional aliases / overrides:
# GMAIL_INTAKE_CLIENT_ID=
# GMAIL_INTAKE_CLIENT_SECRET=
# GMAIL_INTAKE_ADDRESSES=jay.intake.box@gmail.com,julia.hasty@gmail.com
# GMAIL_INTAKE_ADDRESS=jay.intake.box@gmail.com
# GMAIL_INTAKE_TOKENS_DIR=data/gmail-intake-tokens
# GMAIL_INTAKE_TOKEN_PATH=data/gmail-intake-token.json
# GMAIL_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/api/events-finder-gmail/oauth/callback
# GMAIL_EVENTS_QUERY=newer_than:35d (filename:ics OR subject:(invite OR RSVP OR event))
# First-pass event date window (Gmail): keep starts from 2 days ago through 30 days ahead.
# EVENTS_FINDER_INGEST_PAST_DAYS=2
# EVENTS_FINDER_INGEST_FUTURE_DAYS=30
# Preferred when Google OAuth consent UI fails (unverified app): IMAP App Password.
# Create at https://myaccount.google.com/apppasswords (requires 2-Step Verification).
# GMAIL_INTAKE_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Or per-inbox: GMAIL_INTAKE_APP_PASSWORD_JAY_INTAKE_BOX_GMAIL_COM=
# GMAIL_INTAKE_APP_PASSWORD_JULIA_HASTY_GMAIL_COM=

# --- Events Finder: Facebook via Apify ---
# Actor: https://apify.com/apify/facebook-events-scraper
# Token: Apify Console → Settings → Integrations → API tokens
# APIFY_TOKEN=
# Optional:
# APIFY_FACEBOOK_ACTOR_ID=apify/facebook-events-scraper
# FACEBOOK_EVENTS_MAX_EVENTS=30
# FACEBOOK_EVENTS_MAX_CHARGE_USD=1.5
# Apify Free plan monthly credits shown in Settings → Events criteria (default $5).
# FACEBOOK_EVENTS_MONTHLY_CREDITS_USD=5
# Fallback $/event estimate when Apify omits usageTotalUsd on a run.
# FACEBOOK_EVENTS_EST_USD_PER_EVENT=0.04
# FACEBOOK_EVENTS_BILLING_PATH=data/facebook-billing-log.json
# Multiverse School public Google Calendar (ICS from /calendar embed)
# MULTIVERSE_SCHOOL_ICAL_URL=https://calendar.google.com/calendar/ical/.../public/basic.ics
# MULTIVERSE_EVENTS_CACHE_PATH=data/multiverse-events-cache.json
# MULTIVERSE_EVENTS_CACHE_MS=21600000
# FACEBOOK_EVENTS_CACHE_MS=3600000
# FACEBOOK_EVENTS_CACHE_PATH=data/facebook-events-cache.json
# Local SQLite catalog for normalized events (Gmail + Facebook + future sources).
# EVENTS_FINDER_DB_PATH=data/events-finder.db
# Meetup pinned groups (docs/meetup-group-pins.md) → data/meetup-events-cache.json
# MEETUP_EVENTS_CACHE_PATH=data/meetup-events-cache.json
# MEETUP_EVENTS_CACHE_MS=21600000
# Luma pinned calendars (docs/luma-calendar-pins.md) → data/luma-events-cache.json
# LUMA_EVENTS_CACHE_PATH=data/luma-events-cache.json
# LUMA_EVENTS_CACHE_MS=21600000
# Extra Google Calendar ICS feeds (Partiful sync calendar, etc.) — also docs/gcal-ics-pins.md
# EVENTS_FINDER_EXTRA_ICAL_URLS=https://calendar.google.com/calendar/ical/.../private-.../basic.ics
# GCAL_ICS_EVENTS_CACHE_PATH=data/gcal-ics-events-cache.json
# GCAL_ICS_EVENTS_CACHE_MS=3600000
# Eventbrite category browse seeds (comma-separated /b/{city}/{category}/ segments)
# EVENTBRITE_CATEGORY_SEEDS=science-and-tech,arts,music,film-and-media,food-and-drink,community
# Partiful Explore region slug (default sf = Bay Area public discovery)
# PARTIFUL_EXPLORE_REGION=sf
# FACEBOOK_EVENTS_LOCATION=San Francisco
# FACEBOOK_EVENTS_SEARCH_QUERIES=startup San Francisco|hackathon San Francisco|AI San Francisco
# FACEBOOK_EVENTS_WAIT_SECS=180
# Weekly Apify scrape (default Tue 21:00 America/Los_Angeles). Set WEEKLY=0 to disable.
# FACEBOOK_EVENTS_WEEKLY=1
# FACEBOOK_EVENTS_WEEKLY_TZ=America/Los_Angeles
# FACEBOOK_EVENTS_WEEKLY_DOW=2
# FACEBOOK_EVENTS_WEEKLY_HOUR=21
# FACEBOOK_EVENTS_WEEKLY_MINUTE=0

# --- Events Finder: Telegram intake (screenshots / voice / text) ---
# Create a bot with @BotFather → paste token. DM the bot /start to learn your chat id.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_EVENTS_ENABLED=1
# TELEGRAM_ALLOWED_CHAT_IDS=123456789
# Optional:
# TELEGRAM_EVENTS_POLL_MS=2500
# TELEGRAM_EVENTS_OFFSET_PATH=data/telegram-events-offset.json
# TELEGRAM_EVENTS_MEDIA_DIR=public/data/telegram-events
# TELEGRAM_EVENTS_VISION_MODEL=openai/gpt-4o-mini
# TELEGRAM_EVENTS_TEXT_MODEL=openai/gpt-4o-mini
# TELEGRAM_EVENTS_WHISPER_MODEL=openai/whisper-1
# Needs OPENROUTER_API_KEY for vision / NL parse / voice transcription.

# --- v2 placeholders (documented in docs/v2-roadmap.md) ---
# HASS_BASE_URL=
# HASS_TOKEN=

# Optional: DesertUSA + Nominatim superbloom digest (see /api/superbloom-status). Default refresh once per 24h.
# SUPERBLOOM_REFRESH_MS=86400000
# SUPERBLOOM_FETCH_UA=dashbird/1.0 (you@example.com)

# NOAA Geospace magnetosphere frame loops (sidebar Magnetosphere panel). Set MAGNETOSPHERE=0 to disable.
# GEOSPACE_MAGNETOSPHERE_POLL_MS=300000

# Geoelectric field + magnetosphere sidebar: shown only above G1 (NOAA G≥2 or Kp at G2 tier). Set GEOELECTRIC_FIELD=0 or MAGNETOSPHERE=0 to disable.
# SKY_DEBUG_GEOMAGNETIC_ACTIVE=1 forces storm panels + sky strip row for UI testing (synthetic G2).

# Tool Library (below Calendar): paste a product homepage URL.
# Persisted to data/tool-library.json; logos/snapshots in data/tool-library-assets/.
# TOOL_LIBRARY=0 disables the panel API.
# TOOL_LIBRARY_PATH=/var/lib/dashbird/tool-library.json
# TOOL_LIBRARY_ASSETS_DIR=/var/lib/dashbird/tool-library-assets
# Homepage thumbnails via headless Chromium when og/icon scrape fails (default on).
# TOOL_LIBRARY_SCREENSHOT=0
# Tool Library AI enrichment provider for ratings fallback.
# TOOL_LIBRARY_AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=http://localhost
# OPENROUTER_X_TITLE=dashbird

# Web Resource Catalog (favorites/tools/feeds/watch) — see docs/web-resource-catalog.md
# Local JSON by default (data/web-catalog.json). Set Supabase to use shared project B.
# WEB_CATALOG=0 disables /api/web-catalog
# WEB_CATALOG_PATH=/var/lib/dashbird/web-catalog.json
# WEB_CATALOG_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# WEB_CATALOG_SUPABASE_SERVICE_ROLE_KEY=
# WEB_CATALOG_WATCH=1
# WEB_CATALOG_WATCH_MS=900000
# WEB_CATALOG_DISCOVERY=1
# WEB_CATALOG_DISCOVERY_MS=15000
# Optional promote bridge into climate-dash research DB (server only):
# CLIMATE_DASH_SUPABASE_URL=
# CLIMATE_DASH_SUPABASE_SERVICE_ROLE_KEY=
